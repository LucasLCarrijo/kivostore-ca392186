// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  CreatorHub Brasil — schema.prisma                                         ║
// ║  Platform: Stan Store clone adapted for Brazilian market                   ║
// ║  Stack: PostgreSQL + Prisma + Multi-tenant (Workspace-based)               ║
// ║  Version: 1.0.0 — MVP                                                     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 1 — ENUMS                                                         │
// │  All status machines live here for discoverability.                         │
// └──────────────────────────────────────────────────────────────────────────────┘

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProductType {
  DIGITAL   // ebook, template, file download
  COURSE    // modules + lessons in member area
  SERVICE   // coaching call, consultation
  PHYSICAL  // shipped goods (phase 2)
  LEAD_MAGNET // free, captures email
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PriceType {
  ONE_TIME
  RECURRING
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum CheckoutStatus {
  OPEN
  PROCESSING
  COMPLETED
  ABANDONED
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  DISPUTED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  CANCELLED
  EXPIRED
}

enum PaymentMethodType {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
}

enum RefundStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  WON
  LOST
  ACCEPTED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum AffiliateStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum CommissionStatus {
  PENDING       // waiting hold period
  APPROVED      // hold passed, ready for payout
  PAID          // included in a payout
  CANCELLED     // refund/chargeback voided it
}

enum AttributionModel {
  FIRST_CLICK
  LAST_CLICK
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PAUSED
  CANCELLED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  IGNORED
}

enum GatewayProvider {
  PAGARME
  MERCADO_PAGO
  STRIPE
}

enum BlockType {
  HEADING
  TEXT
  IMAGE
  VIDEO_EMBED
  LINK
  PRODUCT_CARD
  LEAD_FORM
  COUNTDOWN
  SOCIAL_LINKS
  WHATSAPP_BUTTON
  DIVIDER
  CUSTOM_HTML
}

enum UpsellType {
  UPSELL
  DOWNSELL
}

enum EventType {
  PAGE_VIEW
  PRODUCT_VIEW
  CHECKOUT_STARTED
  CHECKOUT_COMPLETED
  PURCHASE
  LEAD_CAPTURED
  LINK_CLICKED
  UPSELL_SHOWN
  UPSELL_ACCEPTED
  UPSELL_DECLINED
  AFFILIATE_CLICK
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  UNSUBSCRIBED
}

enum ContentType {
  MODULE
  LESSON
}

enum LessonMediaType {
  VIDEO
  TEXT
  PDF
  AUDIO
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SETTINGS_CHANGE
  PAYMENT_EVENT
  PAYOUT_EVENT
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum EmailEventType {
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  UNSUBSCRIBED
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 2 — AUTH & ORGANIZATION (Multi-tenant core)                       │
// │                                                                            │
// │  Design decision: User is global (can belong to multiple Workspaces).      │
// │  Workspace is the tenant boundary — all business data is scoped here.      │
// │  WorkspaceMember is the join with role-based access.                        │
// └──────────────────────────────────────────────────────────────────────────────┘

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?  // null when using OAuth
  name          String
  avatarUrl     String?
  phone         String?  // E.164 format (+5516994142398)
  timezone      String   @default("America/Sao_Paulo")
  locale        String   @default("pt-BR")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  memberships    WorkspaceMember[]
  sessions       Session[]
  apiKeys        ApiKey[]
  affiliateLinks AffiliateLink[]   // when user acts as affiliate
  auditLogs      AuditLog[]

  @@index([email])
  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  deviceFingerprint String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  name        String    // "Zapier Integration", "n8n webhook"
  keyHash     String    @unique // store hashed, never plain
  prefix      String    // first 8 chars for identification (chub_xxxx)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([workspaceId])
  @@map("api_keys")
}

/// Workspace = Tenant. All business entities are scoped to a workspace.
/// A creator typically has one workspace, but the model supports agencies/teams.
model Workspace {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique // used in URLs: creatorhub.com.br/w/{slug} (admin)
  logoUrl   String?
  timezone  String    @default("America/Sao_Paulo")
  currency  String    @default("BRL") // ISO 4217
  deletedAt DateTime? // soft delete: workspace can be recovered
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relations — everything in the platform hangs off workspace
  members         WorkspaceMember[]
  apiKeys         ApiKey[]
  storefronts     Storefront[]
  products        Product[]
  customers       Customer[]
  orders          Order[]
  checkoutSessions CheckoutSession[]
  payments        Payment[]
  coupons         Coupon[]
  affiliateProgram AffiliateProgram?
  affiliates      Affiliate[]
  gatewayAccounts GatewayAccount[]
  webhookEvents   WebhookEvent[]
  leads           Lead[]
  emailSegments   EmailSegment[]
  subscriptionPlans SubscriptionPlan[]
  subscriptions   Subscription[]
  events          AnalyticsEvent[]
  auditLogs       AuditLog[]
  payouts         Payout[]

  @@index([slug])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(MEMBER)
  invitedAt   DateTime      @default(now())
  acceptedAt  DateTime?
  removedAt   DateTime?     // soft remove from workspace
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId]) // one membership per user per workspace
  @@index([workspaceId])
  @@map("workspace_members")
}

model AuditLog {
  id          String      @id @default(cuid())
  workspaceId String
  userId      String?     // null for system-generated events
  action      AuditAction
  entityType  String      // "Product", "Order", "Payment", etc.
  entityId    String
  metadata    Json?       // diff, before/after, context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Partitioning candidate: high-cardinality, append-only, queried by time range
  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 3 — STOREFRONT / LINK-IN-BIO                                      │
// │                                                                            │
// │  Each workspace can have one primary storefront (the link-in-bio page).    │
// │  Storefront contains ordered Blocks (drag-and-drop builder).               │
// │  Theme holds visual branding (colors, fonts, etc.).                        │
// └──────────────────────────────────────────────────────────────────────────────┘

model Storefront {
  id            String   @id @default(cuid())
  workspaceId   String
  slug          String   @unique // global unique: {slug}.creatorhub.com.br
  customDomain  String?  @unique // "minhaloja.com.br" — verified via CNAME
  domainVerified Boolean @default(false)
  title         String   // "Alexandra Silva"
  bio           String?  // short bio under the name
  avatarUrl     String?
  coverImageUrl String?
  isPublished   Boolean  @default(false)
  seoTitle      String?
  seoDescription String?
  socialImageUrl String? // og:image
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  theme     StorefrontTheme?
  blocks    StorefrontBlock[]

  @@index([workspaceId])
  @@index([slug])
  @@map("storefronts")
}

/// Visual theming for the storefront. 1:1 with Storefront.
model StorefrontTheme {
  id              String  @id @default(cuid())
  storefrontId    String  @unique
  templateKey     String  @default("default") // pre-built theme identifier
  primaryColor    String  @default("#4A26DB")
  secondaryColor  String  @default("#F3F0FF")
  backgroundColor String  @default("#FFFFFF")
  textColor       String  @default("#1A1A2E")
  fontHeading     String  @default("Inter")
  fontBody        String  @default("Inter")
  buttonStyle     String  @default("rounded") // "rounded", "pill", "square"
  customCss       String? // power users / Pro plan
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  storefront Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)

  @@map("storefront_themes")
}

/// Individual content block in the storefront page builder.
/// Ordered by `position`. Content is stored as typed JSON per block type.
model StorefrontBlock {
  id           String    @id @default(cuid())
  storefrontId String
  type         BlockType
  position     Int       // sort order (0-based)
  isVisible    Boolean   @default(true)
  config       Json      // type-specific config (e.g. heading text, link URL, product ID)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  storefront Storefront @relation(fields: [storefrontId], references: [id], onDelete: Cascade)

  @@index([storefrontId, position])
  @@map("storefront_blocks")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 4 — CATALOG & CONTENT                                             │
// │                                                                            │
// │  Product is the core entity. Each product has one or more Prices (offers). │
// │  Digital assets are the deliverables. MembershipContent is the course      │
// │  structure (modules → lessons) gated by product purchase.                  │
// └──────────────────────────────────────────────────────────────────────────────┘

model Product {
  id            String        @id @default(cuid())
  workspaceId   String
  type          ProductType
  status        ProductStatus @default(DRAFT)
  name          String
  slug          String        // unique within workspace
  description   String?       // rich text / markdown
  shortDescription String?    // for cards / link-in-bio
  thumbnailUrl  String?
  coverImageUrl String?
  /// Whether this product appears on the storefront
  isStorefrontVisible Boolean @default(true)
  /// Position in the storefront product list
  storefrontOrder Int         @default(0)
  /// Max number of sales (null = unlimited)
  stockLimit    Int?
  salesCount    Int           @default(0) // denormalized for performance
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?     // soft delete — preserve order history

  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  prices         Price[]
  media          ProductMedia[]
  digitalAssets  DigitalAsset[]
  memberContent  MemberContent[]
  orderItems     OrderItem[]
  checkoutItems  CheckoutLineItem[]
  commissionRules CommissionRule[]
  orderBumps     OrderBump[]        @relation("BumpProduct")
  bumpFor        OrderBump[]        @relation("MainProduct")
  upsellOffers   UpsellOffer[]      @relation("UpsellProduct")
  upsellTriggers UpsellOffer[]      @relation("TriggerProduct")
  affiliateLinks AffiliateLink[]
  entitlements   Entitlement[]
  tags           ProductTag[]

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([workspaceId, type])
  @@map("products")
}

model ProductMedia {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String?
  mimeType  String   // "image/jpeg", "video/mp4"
  sizeBytes Int?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, position])
  @@map("product_media")
}

/// Files delivered upon purchase (ebook PDF, template ZIP, etc.)
model DigitalAsset {
  id            String   @id @default(cuid())
  productId     String
  fileName      String   // "ebook-marketing-digital.pdf"
  fileUrl       String   // S3/R2 presigned or internal path
  fileSizeBytes Int?
  mimeType      String?
  position      Int      @default(0) // if multiple files per product
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("digital_assets")
}

/// Flexible tag system for product categorization.
model Tag {
  id          String       @id @default(cuid())
  workspaceId String
  name        String
  slug        String
  createdAt   DateTime     @default(now())

  products ProductTag[]

  @@unique([workspaceId, slug])
  @@map("tags")
}

model ProductTag {
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

// ── Pricing ──────────────────────────────────────────────────────────────────

/// A product can have multiple prices (offers).
/// Example: "Early Bird R$47", "Normal R$97", "Parcelado 3x R$39".
/// Also supports recurring prices for memberships/subscriptions.
model Price {
  id                String             @id @default(cuid())
  productId         String
  name              String?            // "Oferta de Lançamento"
  type              PriceType          @default(ONE_TIME)
  amount            Decimal            @db.Decimal(12, 2) // in BRL cents? No — full units: 97.00
  currency          String             @default("BRL")
  /// Recurring fields (null for one-time)
  interval          RecurrenceInterval?
  intervalCount     Int?               @default(1) // e.g. every 1 month
  trialDays         Int?               // free trial before first charge
  /// Installments
  maxInstallments   Int                @default(1) // up to 12 for credit card
  /// Promotional pricing
  compareAtAmount   Decimal?           @db.Decimal(12, 2) // "was R$197" strikethrough
  /// PIX discount (very common in Brazil: "10% off for PIX")
  pixDiscountPercent Decimal?          @db.Decimal(5, 2)
  isDefault         Boolean            @default(false) // shown first in checkout
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  product        Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  checkoutItems  CheckoutLineItem[]
  orderItems     OrderItem[]
  subscriptionPlans SubscriptionPlan[]

  @@index([productId, isActive])
  @@map("prices")
}

// ── Member Area Content ──────────────────────────────────────────────────────

/// Hierarchical content for courses / member areas.
/// Top-level = MODULE, children = LESSON.
/// Gated by product purchase (Entitlement).
model MemberContent {
  id          String        @id @default(cuid())
  productId   String
  parentId    String?       // null = top-level module
  type        ContentType
  title       String
  description String?
  position    Int           @default(0) // order within parent
  /// Lesson-specific fields
  mediaType   LessonMediaType?
  mediaUrl    String?       // video URL (Bunny/CF Stream), PDF URL, etc.
  duration    Int?          // seconds (for video/audio)
  textContent String?       // rich text body (for TEXT type lessons)
  isFree      Boolean       @default(false) // free preview lesson
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  product  Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  parent   MemberContent? @relation("ContentHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children MemberContent[] @relation("ContentHierarchy")
  progress LessonProgress[]

  @@index([productId, parentId, position])
  @@map("member_content")
}

/// Tracks a customer's progress through lessons.
model LessonProgress {
  id              String    @id @default(cuid())
  customerId      String
  memberContentId String
  completed       Boolean   @default(false)
  progressPercent Int       @default(0) // 0-100, useful for video
  lastAccessedAt  DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  memberContent MemberContent @relation(fields: [memberContentId], references: [id], onDelete: Cascade)

  @@unique([customerId, memberContentId])
  @@map("lesson_progress")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 5 — CUSTOMERS (BUYERS)                                            │
// │                                                                            │
// │  Customer is separate from User. A buyer doesn't need a platform account.  │
// │  They exist per workspace (same email, different workspaces = separate).    │
// │  If the buyer later signs up as a creator, we can link via email.          │
// └──────────────────────────────────────────────────────────────────────────────┘

model Customer {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  name        String?
  phone       String?   // for WhatsApp notifications
  cpf         String?   // Brazilian tax ID (11 digits), stored hashed or encrypted
  avatarUrl   String?
  metadata    Json?     // custom fields collected at checkout
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders        Order[]
  checkouts     CheckoutSession[]
  subscriptions Subscription[]
  entitlements  Entitlement[]
  lessonProgress LessonProgress[]
  leads         Lead[]

  @@unique([workspaceId, email]) // one customer record per email per workspace
  @@index([workspaceId])
  @@index([email])
  @@map("customers")
}

/// Entitlement = what the customer has access to (products, courses).
/// Created upon successful payment. Revoked on refund/cancellation.
model Entitlement {
  id          String    @id @default(cuid())
  customerId  String
  productId   String
  orderId     String?   // the order that granted this entitlement
  grantedAt   DateTime  @default(now())
  expiresAt   DateTime? // null = lifetime access
  revokedAt   DateTime? // set on refund/cancellation

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([customerId, productId, orderId])
  @@index([customerId])
  @@index([productId])
  @@map("entitlements")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 6 — CHECKOUT, ORDERS & COUPONS                                    │
// │                                                                            │
// │  Flow: CheckoutSession → (payment) → Order + OrderItems                    │
// │  OrderBump = add-on offered on checkout page (checkbox).                    │
// │  UpsellOffer = post-purchase one-click offer.                              │
// └──────────────────────────────────────────────────────────────────────────────┘

model Coupon {
  id              String     @id @default(cuid())
  workspaceId     String
  code            String     // "LANCAMENTO20"
  type            CouponType
  amount          Decimal    @db.Decimal(12, 2) // percentage (20.00) or fixed (50.00)
  currency        String     @default("BRL")
  minOrderAmount  Decimal?   @db.Decimal(12, 2)
  maxUses         Int?       // null = unlimited
  usedCount       Int        @default(0)
  maxUsesPerCustomer Int?    @default(1)
  validFrom       DateTime   @default(now())
  validUntil      DateTime?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@unique([workspaceId, code]) // unique code per workspace
  @@index([workspaceId, isActive])
  @@map("coupons")
}

model OrderBump {
  id            String  @id @default(cuid())
  mainProductId String  // the product being purchased
  bumpProductId String  // the product offered as bump
  headline      String  // "Adicione por apenas R$27!"
  description   String?
  position      Int     @default(0) // order of bumps on checkout
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  mainProduct Product @relation("MainProduct", fields: [mainProductId], references: [id], onDelete: Cascade)
  bumpProduct Product @relation("BumpProduct", fields: [bumpProductId], references: [id], onDelete: Cascade)

  @@unique([mainProductId, bumpProductId])
  @@map("order_bumps")
}

model UpsellOffer {
  id               String     @id @default(cuid())
  triggerProductId  String     // after buying this product…
  upsellProductId   String     // …offer this product
  type             UpsellType @default(UPSELL)
  headline         String
  description      String?
  specialPrice     Decimal?   @db.Decimal(12, 2) // discounted OTO price
  currency         String     @default("BRL")
  position         Int        @default(0) // order in the upsell funnel
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  triggerProduct Product @relation("TriggerProduct", fields: [triggerProductId], references: [id], onDelete: Cascade)
  upsellProduct  Product @relation("UpsellProduct", fields: [upsellProductId], references: [id], onDelete: Cascade)

  @@index([triggerProductId, type, position])
  @@map("upsell_offers")
}

/// Ephemeral checkout state. Created when buyer clicks "Buy".
/// Holds cart, selected payment method, coupon, bump choices before order is created.
model CheckoutSession {
  id              String         @id @default(cuid())
  workspaceId     String
  customerId      String?        // linked after email capture
  status          CheckoutStatus @default(OPEN)
  email           String?        // captured early for abandoned cart recovery
  currency        String         @default("BRL")
  subtotalAmount  Decimal        @db.Decimal(12, 2) @default(0)
  discountAmount  Decimal        @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal        @db.Decimal(12, 2) @default(0)
  couponCode      String?
  /// UTM / attribution
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  referrer        String?
  affiliateLinkId String?
  /// Device info
  ipAddress       String?
  userAgent       String?
  expiresAt       DateTime       // sessions expire after e.g. 30 min
  completedAt     DateTime?
  abandonedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer      Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  affiliateLink AffiliateLink?     @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  lineItems     CheckoutLineItem[]
  order         Order?             // created on success

  @@index([workspaceId, status])
  @@index([email, status]) // abandoned cart queries
  @@index([affiliateLinkId])
  @@index([createdAt])
  @@map("checkout_sessions")
}

model CheckoutLineItem {
  id                String  @id @default(cuid())
  checkoutSessionId String
  productId         String
  priceId           String
  quantity          Int     @default(1)
  unitAmount        Decimal @db.Decimal(12, 2)
  isOrderBump       Boolean @default(false) // true if added via bump checkbox
  createdAt         DateTime @default(now())

  checkoutSession CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)
  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  price           Price           @relation(fields: [priceId], references: [id], onDelete: Restrict)

  @@index([checkoutSessionId])
  @@map("checkout_line_items")
}

/// Finalized purchase. Immutable after creation (amendments via refunds/disputes).
model Order {
  id                String      @id @default(cuid())
  workspaceId       String
  customerId        String
  checkoutSessionId String?     @unique // links back to the checkout that created it
  couponId          String?
  orderNumber       String      // human-readable: "CH-20260215-00001"
  idempotencyKey    String      @unique // prevents double-creation
  status            OrderStatus @default(PENDING)
  currency          String      @default("BRL")
  subtotalAmount    Decimal     @db.Decimal(12, 2)
  discountAmount    Decimal     @db.Decimal(12, 2) @default(0)
  taxAmount         Decimal     @db.Decimal(12, 2) @default(0)
  totalAmount       Decimal     @db.Decimal(12, 2)
  /// Source tracking
  source            String?     // "checkout", "upsell", "admin"
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  affiliateLinkId   String?
  /// Timestamps
  paidAt            DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  customer        Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  checkoutSession CheckoutSession? @relation(fields: [checkoutSessionId], references: [id], onDelete: SetNull)
  coupon          Coupon?          @relation(fields: [couponId], references: [id], onDelete: SetNull)
  affiliateLink   AffiliateLink?   @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  payments        Payment[]
  refunds         Refund[]
  disputes        Dispute[]
  commissions     Commission[]
  entitlements    Entitlement[]
  invoices        Invoice[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status])
  @@index([customerId])
  @@index([orderNumber])
  @@index([affiliateLinkId])
  @@map("orders")
}

model OrderItem {
  id            String   @id @default(cuid())
  orderId       String
  productId     String
  priceId       String
  quantity      Int      @default(1)
  unitAmount    Decimal  @db.Decimal(12, 2)
  totalAmount   Decimal  @db.Decimal(12, 2)
  isOrderBump   Boolean  @default(false)
  isUpsell      Boolean  @default(false)
  createdAt     DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  price   Price   @relation(fields: [priceId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 7 — PAYMENTS (BR-FIRST)                                           │
// │                                                                            │
// │  Multi-gateway with PIX-first design.                                      │
// │  GatewayAccount stores credentials per workspace.                          │
// │  Payment stores the attempt; PixPaymentData stores PIX-specific fields.    │
// │  WebhookEvent ensures idempotent processing of gateway callbacks.          │
// └──────────────────────────────────────────────────────────────────────────────┘

/// Workspace-level gateway credentials. Each workspace connects their own
/// Pagar.me / Mercado Pago / Stripe account for direct payouts.
model GatewayAccount {
  id             String          @id @default(cuid())
  workspaceId    String
  provider       GatewayProvider
  isActive       Boolean         @default(true)
  isPrimary      Boolean         @default(false) // fallback logic uses primary first
  /// Encrypted credentials (API keys, tokens)
  credentialsEnc Json            // encrypted at application layer, never plain
  /// Pagar.me specific: recipient ID for split payments
  recipientId    String?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  payments  Payment[]

  @@unique([workspaceId, provider]) // one account per provider per workspace
  @@index([workspaceId, isActive])
  @@map("gateway_accounts")
}

/// A single payment attempt against an order.
/// An order may have multiple payments (e.g., failed PIX → retry with card).
model Payment {
  id               String            @id @default(cuid())
  workspaceId      String
  orderId          String
  gatewayAccountId String
  idempotencyKey   String            @unique
  status           PaymentStatus     @default(PENDING)
  method           PaymentMethodType
  currency         String            @default("BRL")
  amount           Decimal           @db.Decimal(12, 2)
  gatewayFee       Decimal?          @db.Decimal(12, 2) // fee charged by gateway
  netAmount        Decimal?          @db.Decimal(12, 2) // amount - gatewayFee
  /// Gateway reference IDs
  gatewayPaymentId String?           // Pagar.me transaction ID / Stripe payment_intent
  gatewayChargeId  String?           // charge ID within the payment
  /// Installment info (card)
  installments     Int               @default(1)
  installmentAmount Decimal?         @db.Decimal(12, 2)
  /// Timestamps
  processedAt      DateTime?
  failedAt         DateTime?
  failureReason    String?
  metadata         Json?             // full gateway response for debugging
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  gatewayAccount GatewayAccount @relation(fields: [gatewayAccountId], references: [id], onDelete: Restrict)
  pixData        PixPaymentData?
  refunds        Refund[]

  @@index([workspaceId, createdAt])
  @@index([orderId])
  @@index([gatewayPaymentId])
  @@index([status])
  @@map("payments")
}

/// PIX-specific payment data. 1:1 with Payment when method = PIX.
/// Separated to avoid nullable columns bloating the Payment table.
model PixPaymentData {
  id             String    @id @default(cuid())
  paymentId      String    @unique
  qrCode         String    // base64 QR code image or payload string
  qrCodeUrl      String?   // URL to hosted QR code image
  copyPasteCode  String    // "copia e cola" payload
  txId           String?   // PIX transaction ID (end-to-end)
  expiresAt      DateTime  // PIX QR codes expire (typically 30 min)
  paidAt         DateTime?
  payerCpf       String?   // payer's CPF (masked or encrypted)
  payerName      String?
  payerBankName  String?
  createdAt      DateTime  @default(now())

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([txId])
  @@map("pix_payment_data")
}

model Refund {
  id               String       @id @default(cuid())
  orderId          String
  paymentId        String
  status           RefundStatus @default(PENDING)
  amount           Decimal      @db.Decimal(12, 2)
  currency         String       @default("BRL")
  reason           String?
  gatewayRefundId  String?      // gateway's refund reference
  requestedAt      DateTime     @default(now())
  processedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([paymentId])
  @@map("refunds")
}

model Dispute {
  id                String        @id @default(cuid())
  orderId           String
  status            DisputeStatus @default(OPEN)
  reason            String?
  amount            Decimal       @db.Decimal(12, 2)
  currency          String        @default("BRL")
  gatewayDisputeId  String?
  evidence          Json?         // uploaded evidence (URLs, descriptions)
  respondBy         DateTime?     // deadline to submit evidence
  resolvedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@map("disputes")
}

/// Stores every incoming webhook from payment gateways.
/// Critical for idempotency, debugging, and reprocessing failed events.
model WebhookEvent {
  id              String             @id @default(cuid())
  workspaceId     String?            // null for platform-level webhooks
  provider        GatewayProvider
  eventType       String             // "transaction.paid", "charge.refunded", etc.
  externalEventId String             // gateway's event ID for deduplication
  payload         Json               // raw JSON body from gateway
  headers         Json?              // relevant headers (signature, etc.)
  status          WebhookEventStatus @default(RECEIVED)
  attempts        Int                @default(0)
  lastAttemptAt   DateTime?
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime           @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId]) // idempotency: never process same event twice
  @@index([workspaceId, createdAt])
  @@index([status])
  @@index([provider, eventType])
  @@map("webhook_events")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 8 — AFFILIATES                                                    │
// │                                                                            │
// │  AffiliateProgram = workspace-level config (enabled, default commission).   │
// │  Affiliate = a person participating in the program.                        │
// │  AffiliateLink = per-product tracking link.                                │
// │  Commission = generated per order, linked to payout.                       │
// └──────────────────────────────────────────────────────────────────────────────┘

/// Workspace-level affiliate program settings. 1:1 with Workspace.
model AffiliateProgram {
  id                String           @id @default(cuid())
  workspaceId       String           @unique
  isEnabled         Boolean          @default(false)
  attributionModel  AttributionModel @default(LAST_CLICK)
  cookieDurationDays Int             @default(30) // attribution window
  defaultCommissionPercent Decimal   @db.Decimal(5, 2) @default(20.00)
  minPayoutAmount   Decimal          @db.Decimal(12, 2) @default(50.00) // min R$50 for payout
  holdDays          Int              @default(14) // days before commission is approved
  autoApprove       Boolean          @default(false) // auto-approve affiliate applications
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("affiliate_programs")
}

/// A person participating as an affiliate in a workspace.
/// Can be a platform User (creator who also affiliates) or external (email-only).
model Affiliate {
  id          String          @id @default(cuid())
  workspaceId String
  userId      String?         // null for external affiliates
  email       String
  name        String
  phone       String?
  cpf         String?         // for tax reporting (payout > R$28.559/yr)
  pixKey      String?         // for automatic payouts
  bankAccount Json?           // {bank, agency, account, type}
  status      AffiliateStatus @default(PENDING)
  approvedAt  DateTime?
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links           AffiliateLink[]
  commissions     Commission[]
  payoutItems     PayoutItem[]

  @@unique([workspaceId, email]) // one affiliate record per email per workspace
  @@index([workspaceId, status])
  @@map("affiliates")
}

/// Product-specific or global affiliate tracking link.
model AffiliateLink {
  id          String   @id @default(cuid())
  affiliateId String
  productId   String?  // null = global link for the storefront
  userId      String?  // if affiliate is also a User
  code        String   @unique // short unique code used in URL: ?ref={code}
  clickCount  Int      @default(0) // denormalized for dashboard perf
  createdAt   DateTime @default(now())

  affiliate       Affiliate         @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  product         Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  attributions    AffiliateAttribution[]
  checkoutSessions CheckoutSession[]
  orders          Order[]

  @@index([affiliateId])
  @@index([code])
  @@map("affiliate_links")
}

/// Records a click attribution event. Used to determine which affiliate
/// gets credit for a sale based on the attribution model.
model AffiliateAttribution {
  id              String   @id @default(cuid())
  affiliateLinkId String
  sessionId       String?  // browser session / cookie ID
  ipAddress       String?
  userAgent       String?
  referrer        String?
  expiresAt       DateTime // link cookieDuration from program settings
  convertedAt     DateTime? // set when a purchase happens
  createdAt       DateTime @default(now())

  affiliateLink AffiliateLink @relation(fields: [affiliateLinkId], references: [id], onDelete: Cascade)

  @@index([affiliateLinkId, createdAt])
  @@index([sessionId])
  @@map("affiliate_attributions")
}

/// Per-product commission override. Falls back to program default if no rule exists.
model CommissionRule {
  id          String  @id @default(cuid())
  productId   String
  /// Percentage of sale price (e.g., 30.00 = 30%)
  percent     Decimal @db.Decimal(5, 2)
  /// Or fixed amount per sale (takes precedence if set)
  fixedAmount Decimal? @db.Decimal(12, 2)
  currency    String  @default("BRL")
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId]) // one rule per product (simplicity for MVP)
  @@map("commission_rules")
}

/// Individual commission record generated per order that involves an affiliate.
model Commission {
  id            String           @id @default(cuid())
  orderId       String
  affiliateId   String
  status        CommissionStatus @default(PENDING)
  amount        Decimal          @db.Decimal(12, 2)
  currency      String           @default("BRL")
  ruleSnapshot  Json?            // snapshot of CommissionRule at time of sale
  holdUntil     DateTime?        // date when commission becomes APPROVED
  approvedAt    DateTime?
  paidAt        DateTime?
  cancelledAt   DateTime?
  cancelReason  String?          // "refund", "chargeback", "manual"
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Restrict)
  affiliate Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  payoutItem PayoutItem?

  @@index([orderId])
  @@index([affiliateId, status])
  @@index([status, holdUntil]) // for batch approval job
  @@map("commissions")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 9 — PAYOUTS                                                       │
// │                                                                            │
// │  Payout = a batch transfer to an affiliate (or workspace owner).           │
// │  PayoutItem = individual commission included in the payout.                │
// │  Supports both automatic (split) and manual (bank transfer) payouts.       │
// └──────────────────────────────────────────────────────────────────────────────┘

model Payout {
  id            String       @id @default(cuid())
  workspaceId   String
  status        PayoutStatus @default(PENDING)
  totalAmount   Decimal      @db.Decimal(12, 2)
  currency      String       @default("BRL")
  method        String?      // "pix", "bank_transfer", "gateway_split"
  gatewayRef    String?      // gateway transfer ID
  processedAt   DateTime?
  failedAt      DateTime?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  items     PayoutItem[]

  @@index([workspaceId, status])
  @@index([createdAt])
  @@map("payouts")
}

model PayoutItem {
  id           String  @id @default(cuid())
  payoutId     String
  affiliateId  String
  commissionId String  @unique // 1:1 — each commission is paid out once
  amount       Decimal @db.Decimal(12, 2)
  currency     String  @default("BRL")
  createdAt    DateTime @default(now())

  payout     Payout     @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  affiliate  Affiliate  @relation(fields: [affiliateId], references: [id], onDelete: Restrict)
  commission Commission @relation(fields: [commissionId], references: [id], onDelete: Restrict)

  @@index([payoutId])
  @@index([affiliateId])
  @@map("payout_items")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 10 — LEADS & EMAIL                                                │
// │                                                                            │
// │  Lead = captured via forms on storefront / checkout.                        │
// │  EmailSegment = basic segmentation for email marketing.                    │
// │  EmailEvent = delivery/open/click tracking.                                │
// └──────────────────────────────────────────────────────────────────────────────┘

model Lead {
  id          String     @id @default(cuid())
  workspaceId String
  customerId  String?    // linked if they later become a customer
  email       String
  name        String?
  phone       String?
  source      String?    // "storefront", "checkout", "lead_magnet", "manual"
  sourceDetail String?   // specific form/page ID
  status      LeadStatus @default(NEW)
  tags        String[]   // PostgreSQL text array for simple tagging
  metadata    Json?      // custom fields from form
  optInAt     DateTime?  // LGPD: explicit consent timestamp
  optInIp     String?    // LGPD: IP at time of consent
  unsubscribedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  segments  LeadSegmentMember[]

  @@unique([workspaceId, email])
  @@index([workspaceId, status])
  @@index([workspaceId, createdAt])
  @@map("leads")
}

model EmailSegment {
  id          String   @id @default(cuid())
  workspaceId String
  name        String   // "Compradores do Curso X", "Leads Novos"
  description String?
  /// Dynamic filter as JSON (evaluated at send time)
  /// e.g. {"tags": ["curso_x"], "status": "CONVERTED"}
  filterRules Json?
  memberCount Int      @default(0) // denormalized, refreshed periodically
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members   LeadSegmentMember[]

  @@index([workspaceId])
  @@map("email_segments")
}

model LeadSegmentMember {
  leadId    String
  segmentId String
  addedAt   DateTime @default(now())

  lead    Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  segment EmailSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@id([leadId, segmentId])
  @@map("lead_segment_members")
}

model EmailEvent {
  id          String         @id @default(cuid())
  workspaceId String
  leadId      String?
  email       String
  eventType   EmailEventType
  messageId   String?        // SES/Resend message ID
  campaignId  String?        // internal campaign/sequence reference
  metadata    Json?          // link clicked, bounce reason, etc.
  createdAt   DateTime       @default(now())

  // No FK to workspace — high-volume, partitioned by time
  @@index([workspaceId, createdAt])
  @@index([email, eventType])
  @@index([messageId])
  @@map("email_events")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 11 — SUBSCRIPTIONS (RECURRING)                                    │
// │                                                                            │
// │  For membership products with recurring billing.                           │
// │  SubscriptionPlan links Price (recurring) to a product.                    │
// │  Subscription is per-customer, generates Invoices on each billing cycle.   │
// └──────────────────────────────────────────────────────────────────────────────┘

model SubscriptionPlan {
  id          String   @id @default(cuid())
  workspaceId String
  priceId     String   // references the recurring Price
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  price         Price          @relation(fields: [priceId], references: [id], onDelete: Restrict)
  subscriptions Subscription[]

  @@index([workspaceId, isActive])
  @@map("subscription_plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  workspaceId        String
  customerId         String
  subscriptionPlanId String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  cancelledAt        DateTime?
  cancelReason       String?
  trialEndsAt        DateTime?
  gatewaySubId       String?            // gateway subscription ID
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  customer         Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id], onDelete: Restrict)
  invoices         Invoice[]

  @@index([workspaceId, status])
  @@index([customerId])
  @@index([currentPeriodEnd]) // for batch renewal jobs
  @@map("subscriptions")
}

model Invoice {
  id              String        @id @default(cuid())
  subscriptionId  String?
  orderId         String?
  invoiceNumber   String        @unique // "INV-2026-00001"
  status          InvoiceStatus @default(DRAFT)
  currency        String        @default("BRL")
  subtotalAmount  Decimal       @db.Decimal(12, 2)
  taxAmount       Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(12, 2)
  dueDate         DateTime?
  paidAt          DateTime?
  /// NFS-e (Brazilian electronic service invoice)
  nfseNumber      String?       // municipal NFS-e number
  nfseUrl         String?       // URL to the issued NFS-e PDF
  nfseIssuedAt    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([orderId])
  @@index([status])
  @@map("invoices")
}

// ┌──────────────────────────────────────────────────────────────────────────────┐
// │  SECTION 12 — ANALYTICS EVENTS                                             │
// │                                                                            │
// │  Append-only event stream. High cardinality — designed for partitioning.   │
// │  Aggregations are computed via materialized views or ClickHouse (phase 2). │
// └──────────────────────────────────────────────────────────────────────────────┘

/// Raw analytics event. Insert-only, never updated.
/// Partition by createdAt (monthly) in production.
model AnalyticsEvent {
  id          String    @id @default(cuid())
  workspaceId String
  eventType   EventType
  /// Context
  sessionId   String?   // anonymous browser session
  customerId  String?   // if identified
  productId   String?
  orderId     String?
  affiliateLinkId String?
  /// Request metadata
  url         String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  ipAddress   String?
  userAgent   String?
  country     String?   // resolved from IP
  region      String?
  city        String?
  device      String?   // "mobile", "desktop", "tablet"
  browser     String?
  os          String?
  /// Custom properties
  properties  Json?     // flexible key-value for event-specific data
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Partitioning candidate: partition by (workspaceId, createdAt) monthly
  @@index([workspaceId, eventType, createdAt])
  @@index([workspaceId, createdAt])
  @@index([sessionId])
  @@index([customerId, createdAt])
  @@index([productId, eventType])
  @@map("analytics_events")
}
